# Control-plane service alerts (Galera, RabbitMQ, OVN, Kolla containers).
#
# Companion to ceph-alerts.rules (Ceph) and node-exporter-alerts.rules (hosts).
# Kolla auto-appends every *.rules under node_custom_config/prometheus/ to the
# generated rule_files (node_custom_config: /etc/kolla/config, globals.yml:47),
# so dropping this file in is enough -- no Prometheus config change.
#
# Two paths feed these rules (see docs/runbooks/control-plane-alerts.md):
#   - PromQL path (this file's first three groups): conditions that map to
#     metrics the exporters already scrape -- Galera wsrep, RabbitMQ, cAdvisor.
#   - Textfile path (RabbitMQ partition / OVN groups, added by U4): gauges the
#     per-controller control-plane-alert-collector writes, because the
#     partition_handling=ignore split-brain test and the OVN stale-chassis
#     set-difference cannot be faithfully expressed from current metrics.
#
# Every rule mirrors a health-gate predicate; the description names its
# ansible/roles/health-gate/tasks/*.yml counterpart so a future gate change
# flags the alert that must follow (R10). The runbook carries the full table.
#
# All rules ship at severity: warning per R7 (warn-first soak); the landmines
# promote to critical by editing the label only -- both labels already route
# (operator-confirmed), so no Alertmanager change. See the runbook for the
# promotion checklist.
#
# Annotations deliberately avoid {{ $value }} / {{ $labels }} interpolation so
# the promtool unit tests can assert them deterministically; the summary's
# label refs ($labels.instance / $labels.name) are enough to locate the target.
#
# METRIC-NAME CONFIRMATION (R1/R2/R3 risk): the metric names below are the
# upstream-standard names for mysqld_exporter, the rabbitmq_prometheus plugin,
# and cAdvisor, but a wrong name yields a rule that never fires silently. The
# promtool unit tests validate rule LOGIC against these exact names; they do
# NOT prove the metric is produced. Confirm each metric exists in live
# Prometheus (Status -> Targets / the /api/v1/label/__name__/values endpoint)
# before trusting these rules. This is the deploy-time guard the plan defers.
#
# Cluster sizes are hardcoded thresholds (PromQL cannot read the Ansible
# inventory): Galera/RabbitMQ expect 3 (controller group: openstack01/02/04),
# OVN expects 4 chassis (compute group: openstack01/02/04/05). Update these and
# the runbook if the group membership changes.

groups:
  - name: "control-plane galera"
    rules:
      # health-gate galera.yml -- state == 'Synced'. wsrep_local_state 4 ==
      # Synced; anything else (Joining/Donor/Desynced/Joined) still answers TCP
      # but is unsafe to lose.
      - alert: GaleraNodeNotSynced
        expr: mysql_global_status_wsrep_local_state != 4
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Galera node not Synced (instance {{ $labels.instance }})"
          description: "wsrep_local_state != 4 (Synced); node answers queries but is unsafe to lose. Mirrors health-gate galera.yml state check."
      # health-gate galera.yml -- ready == 'ON'. wsrep_ready goes OFF when the
      # node cannot accept writes, which also covers the non-Primary case.
      - alert: GaleraNodeNotReady
        expr: mysql_global_status_wsrep_ready != 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Galera node not ready (instance {{ $labels.instance }})"
          description: "wsrep_ready != 1 (ON); node cannot accept writes, typically a non-Primary component. Mirrors health-gate galera.yml ready/status check."
      # health-gate galera.yml -- size == expected (3 controllers). A shrunk
      # cluster means a peer was already lost; losing another risks quorum.
      - alert: GaleraClusterShrunk
        expr: mysql_global_status_wsrep_cluster_size < 3
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Galera cluster shrunk below 3 (instance {{ $labels.instance }})"
          description: "wsrep_cluster_size < 3 (expected 3: openstack01/02/04); a peer was lost. Mirrors health-gate galera.yml expected-size assert."

  - name: "control-plane rabbitmq"
    rules:
      # RabbitMQ raised its own memory high-watermark alarm (rabbitmq_prometheus
      # plugin). When active, RabbitMQ blocks publishers -- a real outage signal,
      # not a soft threshold. No direct health-gate counterpart (the gate checks
      # partitions/membership, covered by the textfile path).
      - alert: RabbitMQMemoryAlarm
        expr: rabbitmq_alarms_memory_used_watermark == 1
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "RabbitMQ memory alarm active (instance {{ $labels.instance }})"
          description: "RabbitMQ memory high-watermark alarm is active; publishers are blocked. Free memory or raise the watermark."
      # Node-down via the Prometheus scrape target. Confirm the rabbitmq job
      # label against live Prometheus (Status -> Targets); Kolla's job name may
      # differ from the .*rabbitmq.* guess. The textfile path (U4) independently
      # catches a node missing from the cluster's running-node count.
      - alert: RabbitMQNodeDown
        expr: up{job=~".*rabbitmq.*"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "RabbitMQ scrape target down (instance {{ $labels.instance }})"
          description: "Prometheus cannot scrape this RabbitMQ node. Confirm the job label matches the live target. Complements the textfile membership check."

  - name: "control-plane containers"
    rules:
      # Kolla service container crash-looping: container_start_time_seconds
      # changes on every (re)start, so > 5 starts in an hour is a restart loop.
      # cAdvisor is on by Kolla default; the `name` label is the Docker name.
      - alert: KollaContainerRestartLooping
        expr: changes(container_start_time_seconds{name!=""}[1h]) > 5
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Kolla container restart-looping ({{ $labels.name }} on {{ $labels.instance }})"
          description: "Container restarted > 5 times in the last hour."
      # Container down/absent: cAdvisor stops refreshing container_last_seen once
      # the container is gone, so a growing time()-last_seen gap means the
      # container stopped. This is the opensearch-stopped class of failure.
      # LIMITATION: a container that stays *running but Docker-unhealthy*
      # (opensearch's exact 4-week state) keeps updating last_seen -- cAdvisor
      # does not expose Docker healthcheck status, so this rule will NOT catch
      # it. That gap is documented in the runbook with a follow-up (emit a
      # docker-health gauge from the U3 collector).
      - alert: KollaContainerDown
        # Threshold must stay BELOW Prometheus --query.lookback-delta (default
        # 5m): cAdvisor drops a removed container's series, after which the
        # subtraction has no data. 120s catches the stop transition with margin;
        # the expr threshold is the debounce, so no for:. Steady-state absence
        # (gone for hours) is NOT caught here -- see the runbook gap note
        # (docker-ps follow-up).
        # The neutron_ovn_metadata_agent_haproxy_ovnmeta-<datapath-uuid>
        # containers are spawned/destroyed per metadata-enabled network by the
        # OVN metadata agent; a tenant deleting a network tears one down and
        # flaps this alert. They share the neutron-metadata-agent image with the
        # persistent agent, so they must be excluded by name, not image. The
        # real neutron_ovn_metadata_agent container (no haproxy_ovnmeta- suffix)
        # is still monitored.
        expr: |
          time() - (
            container_last_seen{name!="", name!~"neutron_ovn_metadata_agent_haproxy_ovnmeta-.*", image!~"quay\\.io/ceph/ceph.*"}
            or
            container_last_seen{name=~"ceph-.*", image=~"quay\\.io/ceph/ceph.*"}
          ) > 120
        labels:
          severity: warning
        annotations:
          summary: "Kolla container down ({{ $labels.name }} on {{ $labels.instance }})"
          description: "Container not seen by cAdvisor for > 2 minutes; it has likely stopped. Bounded by Prometheus lookback-delta -- catches the stop transition, not steady-state absence (see runbook)."

  # --- Textfile path (U4): rules over the gauges control_plane_alert_collector.py
  # writes per host. node= is the reporting node; PromQL aggregates so a single
  # minority node reporting a partition (the partition_handling=ignore case) is
  # enough to fire. ---
  - name: "control-plane rabbitmq partition"
    rules:
      # health-gate rabbitmq.yml -- partitions == 0 from every node.
      - alert: RabbitMQPartitionDetected
        expr: cpa_rabbitmq_partitions > 0
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "RabbitMQ partition reported by {{ $labels.node }}"
          description: "A node reports a network partition; under partition_handling=ignore this is the only split-brain signal. Mirrors health-gate rabbitmq.yml partition assert."
      # health-gate rabbitmq.yml -- running_nodes == expected from every node.
      - alert: RabbitMQMembershipShrunk
        expr: cpa_rabbitmq_running_nodes < cpa_rabbitmq_expected_nodes
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "RabbitMQ membership shrunk on {{ $labels.node }}"
          description: "A node sees fewer running RabbitMQ nodes than expected. Mirrors health-gate rabbitmq.yml running-node-count assert."

  - name: "control-plane ovn"
    rules:
      # health-gate ovn.yml -- no expected chassis missing.
      - alert: OVNChassisMissing
        expr: cpa_ovn_chassis_missing > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "OVN chassis missing (reported by {{ $labels.node }})"
          description: "An expected chassis host has no live SB-DB chassis row. Mirrors health-gate ovn.yml missing-chassis assert."
      # health-gate ovn.yml -- no stale chassis rows.
      - alert: OVNChassisStale
        expr: cpa_ovn_chassis_stale > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "OVN stale chassis (reported by {{ $labels.node }})"
          description: "A SB-DB chassis row has no matching expected host; a stale chassis can strand floating IPs. Mirrors health-gate ovn.yml stale-chassis assert."
      # health-gate ovn.yml -- every ovn-controller SB status == 'connected'.
      - alert: OVNControllerNotConnected
        expr: cpa_ovn_controller_connected == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ovn-controller not connected to SB DB on {{ $labels.node }}"
          description: "ovn-controller reports an SB connection status other than connected. Mirrors health-gate ovn.yml connection-status assert."

  - name: "control-plane collector health"
    rules:
      # A landmine check could not run (fail-safe surfaced *_check_failed 1):
      # its gauge cannot be trusted, so absence of a partition/chassis alert is
      # not proof of health. Mirrors health-gate's refuse-rather-than-guess.
      - alert: ControlPlaneCollectorCheckFailed
        expr: cpa_rabbitmq_check_failed > 0 or cpa_ovn_chassis_check_failed > 0 or cpa_ovn_controller_check_failed > 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Control-plane landmine check failed on {{ $labels.node }}"
          description: "A landmine check could not run (CLI error or unexpected output); its gauge cannot be trusted. Inspect the collector on this node."
      # The collector itself stopped refreshing -- the landmine gauges are stale,
      # so the cluster is effectively unmonitored for these conditions.
      - alert: ControlPlaneCollectorStale
        # node_exporter re-exports the textfile every scrape, so this series
        # persists with a frozen value when the collector dies and the
        # subtraction grows reliably (unlike a live exporter that goes stale).
        # 600s = ~5 missed 2-minute runs; the threshold is the debounce, no for:.
        expr: time() - cpa_collector_last_run_timestamp_seconds > 600
        labels:
          severity: warning
        annotations:
          summary: "Control-plane landmine collector stale on {{ $labels.node }}"
          description: "The collector has not refreshed its textfile in over 10 minutes; landmine gauges are stale. Check the control-plane-alert-collector timer."
