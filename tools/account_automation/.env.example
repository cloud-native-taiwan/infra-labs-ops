# Google Sheets
# Accepts inline service account JSON or a path to a JSON file.
INFRA_LABS_GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
INFRA_LABS_SPREADSHEET_ID=your-spreadsheet-id-here
INFRA_LABS_WORKSHEET_NAME=Sheet1

# OpenStack
INFRA_LABS_OPENSTACK_CLOUD=default
INFRA_LABS_OPENSTACK_DOMAIN_ID=your-domain-id
INFRA_LABS_OPENSTACK_MEMBER_ROLE=member
INFRA_LABS_OPENSTACK_LB_ROLE=load-balancer_member

# Resend Email
INFRA_LABS_RESEND_API_KEY=re_your_api_key_here
INFRA_LABS_RESEND_FROM_EMAIL=infra-labs@your-domain.com

# Behavior
INFRA_LABS_EXPIRY_WARNING_DAYS=14
INFRA_LABS_GRACE_PERIOD_DAYS=7
INFRA_LABS_DRY_RUN=false
INFRA_LABS_LOG_LEVEL=INFO
