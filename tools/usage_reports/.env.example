# OpenStack
INFRA_LABS_OPENSTACK_CLOUD=default

# CloudKitty
# Override the rating service URL discovered via the Keystone service catalog.
# Leave empty to use catalog discovery (recommended).
# INFRA_LABS_CLOUDKITTY_ENDPOINT_OVERRIDE=

# Resend Email
INFRA_LABS_RESEND_API_KEY=re_your_api_key_here
INFRA_LABS_RESEND_FROM_EMAIL=infra-labs@your-domain.com
INFRA_LABS_ADMIN_EMAIL=infra@cloudnative.tw

# Behavior
INFRA_LABS_REPORT_TIMEZONE=Asia/Taipei
INFRA_LABS_DELIVERY_MANIFEST_PATH=/var/lib/usage-reports/deliveries.json
INFRA_LABS_DRY_RUN=false
INFRA_LABS_LOG_LEVEL=INFO
